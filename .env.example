# imgdelta environment variables
# Copy to .env in the repo root and fill in your values.
# This file is gitignored — never commit secrets.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=imgdelta
POSTGRES_PASSWORD=change_me

# Full DSN used by imgdelta and sqlx migrations.
# Local (docker-compose): postgres://imgdelta:change_me@localhost/imgdelta
# YC VM: postgres://imgdelta:change_me@10.128.0.5/imgdelta
DATABASE_URL=postgres://imgdelta:change_me@localhost/imgdelta

# ── S3 / Yandex Cloud Object Storage ─────────────────────────────────────────
# YC service account key (create via: yc iam access-key create --service-account-id ...)
AWS_ACCESS_KEY_ID=your_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_here

# Default bucket name used by S3Storage when s3_bucket is not set in config.
# S3_BUCKET=julesimf-imgdelta-storage
